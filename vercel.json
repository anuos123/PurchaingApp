{
  "name": "purchaing-app",
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/client/dist/assets/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/client/dist/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/client/dist/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/$1"
    }
  ]
}