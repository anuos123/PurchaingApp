.container {
  padding: 15px;
  padding-bottom: 80px;
}

.table-container {
  border: 1px solid #eee;
  border-radius: 8px;
  overflow: hidden;
}

.table-header {
  display: flex;
  background: #f8f9fa;
  font-weight: bold;
  font-size: 13px;
  color: #333;
}

.table-row {
  display: flex;
  border-bottom: 1px solid #eee;
}

.table-row:last-child {
  border-bottom: none;
}

.th, .td {
  padding: 12px 8px;
  text-align: left;
  font-size: 13px;
}

.th:nth-child(1), .td:nth-child(1) { width: 20%; }
.th:nth-child(2), .td:nth-child(2) { width: 10%; text-align: center; }
.th:nth-child(3), .td:nth-child(3) { width: 12%; text-align: center; }
.th:nth-child(4), .td:nth-child(4) { width: 12%; text-align: center; }
.th:nth-child(5), .td:nth-child(5) { width: 15%; }
.th:nth-child(6), .td:nth-child(6) { width: 15%; text-align: center; }
.th:nth-child(7), .td:nth-child(7) { width: 16%; text-align: center; }

.status-picker {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

.select-item {
  border: 1px solid #eee;
  border-radius: 8px;
  margin-bottom: 10px;
  overflow: hidden;
}

.select-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: #fafafa;
}

.select-body {
  padding: 0 12px;
}