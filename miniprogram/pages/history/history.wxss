.container {
  padding: 15px;
  padding-bottom: 80px;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 24px;
  font-weight: bold;
  color: #333;
}

.stat-label {
  display: block;
  font-size: 12px;
  color: #666;
  margin-top: 5px;
}

.history-item {
  border: 1px solid #eee;
  border-radius: 8px;
  margin-bottom: 15px;
  overflow: hidden;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px;
  background: #fafafa;
  border-bottom: 1px solid #eee;
}

.history-items {
  padding: 10px 15px;
}

.history-row {
  display: flex;
  padding: 8px 0;
  font-size: 14px;
  border-bottom: 1px dashed #eee;
}

.history-row:last-child {
  border-bottom: none;
}