{
  "name": "purchasing-system",
  "version": "1.0.0",
  "description": "采购系统 - 包含客户端、服务端和商家端",
  "scripts": {
    "start": "cd server && node server.js",
    "dev": "cd server && nodemon server.js",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "serverless-http": "^3.2.0"
  },
  "keywords": ["采购", "系统", "client", "server", "merchant"],
